-- (Customer Rating vs Sales Performance)
--Q14 Is there a meaningful relationship between a product's average customer rating and its sales volume? 
-- Which high-revenue products have dangerously low ratings and represent a churn risk?


-- Query
SELECT 
	p.product_name,
	ROUND(SUM(s.gross_revenue_usd),0) rev,
	ROUND(AVG(fct.rating),0) avg_rating
FROM fact_sales_transactions s
JOIN dim_products p ON s.product_id = p.product_id
LEFT JOIN fact_customer_reviews fct ON s.product_id = fct.product_id
WHERE order_status NOT IN ('returned','cancelled')
GROUP BY p.product_name
HAVING avg_rating < 4
ORDER BY rev DESC


-- (Sustainability Certification Premium)
--Q15 Do products carrying sustainability certifications like Rainforest Alliance, RSPO, Vegan Certified command higher prices or sell at higher volumes? 
-- Does this support the business case for our sustainability investment?


-- Query
SELECT
	ROW_NUMBER() OVER(ORDER BY gross_revenue DESC) Rankk,
	(CASE WHEN sustainability_cert IS NULL THEN 'No Certification' ELSE sustainability_cert END) cert_status,
	COUNT(DISTINCT product_name) product_count,
	COUNT(quantity_sold) Quantity_sold,
	ROUND(AVG(unit_price_usd)) Avg_unit_price,
	SUM(gross_revenue_usd) gross_revenue
FROM unilever_analytics.vw_sales_enriched
WHERE order_status NOT IN ('returned','cancelled')
GROUP BY cert_status
ORDER BY  gross_revenue DESC


-- (Stockout Revenue Loss)
--Q16 Which products have the highest stockout days across our markets? What is the estimated revenue being lost as a direct result of those inventory gaps?


-- Query
SELECT
	p.product_name,
	SUM(COALESCE(fi.stockout_days,0)) stock_out_days,
	p.base_price_usd,
	ROUND(AVG(fi.units_sold_month),0) Avg_monthly_units,
	ROUND((SUM(COALESCE(fi.stockout_days,0)) / 30) * AVG(fi.units_sold_month) * p.base_price_usd, 0) est_revenue_lost_usd
FROM unilever_analytics.dim_products p
LEFT JOIN fact_inventory fi ON p.product_id = fi.product_id
GROUP BY p.product_name, p.base_price_usd
HAVING stock_out_days > 0
ORDER BY stock_out_days	DESC


