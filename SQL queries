

-- EXECUTIVE REVENUE OVERVIEW


-- (Revenue by segment)
--Q1 which among our 5 product segments genrate the highest gross and net revenue for us? and how has the trend line been accross the years, exclude returned and cancelled orders


-- Query 
WITH gross_revenue AS (
SELECT 
	segment_name,
	YEAR(transaction_date) year,
	SUM(gross_revenue_usd) gross_revenue,
	SUM(net_revenue_usd) net_revenue
FROM vw_sales_enriched
WHERE order_status NOT IN ('returned', 'cancelled')
GROUP BY segment_name, YEAR(transaction_date)
)
SELECT 
	segment_name,
	year,
	gross_revenue,
	net_revenue,
	CONCAT(ROUND(gross_revenue * 100.0 / sum(gross_revenue) OVER(PARTITION BY year), 2), '%') as gross_revenue_pct
FROM gross_revenue
ORDER BY year, gross_revenue DESC


-- (Year over Year growth)
--Q2 What is the year-over-year (YoY) revenue growth % for each segment?


-- Query 
WITH yearly_revenue AS (
SELECT
	segment_name,
	YEAR(transaction_date) current_year,
	SUM(gross_revenue_usd) total_revenue
FROM vw_sales_enriched
GROUP BY segment_name, YEAR(transaction_date)
),
lagged AS(
SELECT
	segment_name,
	current_year,
	total_revenue ,
	LAG(total_revenue) OVER(PARTITION BY  segment_name ORDER BY current_year) prev_year_revenue
FROM yearly_revenue
)
SELECT 
	segment_name,
	current_year,
	total_revenue current_year_revenue,
	prev_year_revenue,
	ROUND(((total_revenue - prev_year_revenue) / nullif(prev_year_revenue, 0)) * 100, 2) YoY_revenue_prct
FROM lagged
ORDER BY segment_name, current_year


-- (Gross Margin vs Target)
--Q3 Which segments and categories are performing above or below their gross margin targets? Where exactly is margin compression happening?


-- Query
SELECT 
	segment_name,
	category_name,
	AVG(gross_margin_pct) avg_gross_margin,
	AVG(margin_target) avg_margin_target,
	CASE WHEN AVG(gross_margin_pct) < AVG(margin_target) THEN 'Below target margin'
		 WHEN AVG(gross_margin_pct) > AVG(margin_target) THEN 'Already met target margin'
		 ELSE 'On Target'
	END AS target_verification
FROM unilever_analytics.vw_sales_enriched
WHERE order_status NOT IN ('cancelled','returned')
GROUP BY segment_name, category_name


-- (Revenue by Channel)
--Q4 Which sales channels contribute most to our net revenue, and which are the most profitable in terms of margin?


-- Query
SELECT 
	channel_name,
	SUM(net_revenue_usd) net_revenue,
	SUM(gross_profit_usd) gross_profit,
	ROUND(SUM(gross_profit_usd) / SUM(net_revenue_usd) * 100, 2) profit_margin_pct 
FROM unilever_analytics.vw_sales_enriched
WHERE order_status NOT IN ('cancelled','returned')
GROUP BY channel_name
ORDER BY net_revenue desc


-- (Returns & Cancellations Impact)
--Q5 What is our order return rate and cancellation rate, both overall and broken down by segment? 
-- What is the total financial impact of these in USD.


-- Query
SELECT 
	segment_name,
	COUNT(transaction_id) total_orders,
	SUM(CASE WHEN order_status = 'cancelled' THEN 1 ELSE 0 END) cancelled, 
	SUM(CASE WHEN order_status = 'returned' THEN 1 ELSE 0 END) returned,
	ROUND(sum(CASE WHEN order_status = 'cancelled' THEN 1 else 0 END) / count(transaction_id) * 100, 2) cancelled_rate_prct,
	ROUND(sum(CASE WHEN order_status = 'returned' THEN 1 else 0 END) / count(transaction_id) * 100, 2) returned_rate_prct,
	ROUND(sum(CASE WHEN order_status IN ('cancelled', 'returned') THEN gross_revenue_usd ELSE 0 END),0) financial_impact_per_seg,
	ROUND(sum(sum(CASE WHEN order_status IN ('cancelled', 'returned') THEN gross_revenue_usd ELSE 0 END)) OVER(), 0) total_financial_impact
FROM unilever_analytics.vw_sales_enriched
GROUP BY segment_name


-- (Top revenue market)
--Q6 Which of our 40 markets generate the highest net revenue? (p1)
-- Which emerging markets are showing the fastest growth year over year? (p2)


-- Query
-- (p1)
SELECT 
country_name,
market_maturity,
region,
sum(net_revenue_usd) current_year_net_revenue
from vw_sales_enriched
where order_status not in ('returned','cancelled')
group by country_name,market_maturity, region
order by current_year_net_revenue desc

-- p(2)
WITH cte1 AS (
SELECT
	country_name,
	YEAR(transaction_date) sale_year,
	SUM(net_revenue_usd) net_revenue,
	market_maturity
FROM unilever_analytics.vw_sales_enriched
WHERE order_status NOT IN ('returned', 'cancelled')
AND market_maturity = 'Emerging'
GROUP BY country_name, YEAR(transaction_date), market_maturity

),
cte2 AS (
SELECT
	sale_year,
	country_name,
	net_revenue,
	market_maturity,
	LAG(net_revenue) OVER(PARTITION BY country_name ORDER BY sale_year) prev_year_revenue
FROM cte1
)
SELECT
	country_name,
	market_maturity,
	sale_year,
	net_revenue,
	prev_year_revenue,
	ROUND((net_revenue - prev_year_revenue) / prev_year_revenue * 100,2) YoY_percentage
FROM cte2
WHERE prev_year_revenue IS NOT NULL
ORDER BY YoY_percentage DESC


