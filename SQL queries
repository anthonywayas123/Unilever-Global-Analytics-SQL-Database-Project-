-- (Product-Market Fit by Country)
--Q9 Which products sell disproportionately well in specific countries? (p1)
-- Are there untapped opportunities where products performing well elsewhere are not yet gaining traction in certain markets? (p2)


-- Query
-- (p1)
WITH ranked AS (
SELECT 
	country_name,
	product_name,
	SUM(gross_revenue_usd) gross_revenue,
	ROW_NUMBER() over(PARTITION BY country_name ORDER BY SUM(gross_revenue_usd) DESC) rnk
FROM unilever_analytics.vw_sales_enriched
WHERE order_status NOT IN ('returned','cancelled')
GROUP BY country_name, product_name
ORDER BY SUM(gross_revenue_usd) DESC
)
SELECT * FROM ranked
WHERE rnk = 1
ORDER BY gross_revenue DESC

--(p2)
WITH ranked AS (
SELECT 
	product_name,
	SUM(gross_revenue_usd) gross_revenue,
	ROW_NUMBER() over(ORDER BY SUM(gross_revenue_usd) DESC) rnk
FROM unilever_analytics.vw_sales_enriched
WHERE order_status NOT IN ('returned','cancelled')
GROUP BY product_name
),
glob AS (
SELECT
	v.country_name,
	v.product_name,
	SUM(gross_revenue_usd) gross_revenue
FROM vw_sales_enriched v 
LEFT JOIN ranked r ON v.product_name = r.product_name
WHERE r.rnk <= 10
AND v.order_status NOT IN ('returned','cancelled')
GROUP BY v.country_name, v.product_name

)
SELECT * FROM glob
WHERE gross_revenue < 500
ORDER BY gross_revenue 


