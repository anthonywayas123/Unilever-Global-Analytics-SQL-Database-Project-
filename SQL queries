-- (Acquisition Channel Lifetime Value)
--Q19 Which acquisition channels, Social Media, TV Ad, Retail Store, Word of Mouth, and Distributor are producing the highest lifetime value customers? Where should we be investing our acquisition budget?


-- Query
SELECT 
	c.acquisition_channel,
	COUNT(fs.transaction_id) order_count,
	ROUND(SUM(fs.gross_revenue_usd),0) gross_revenue,
	ROUND(SUM(c.lifetime_value_usd),0) lifetime_value
FROM unilever_analytics.dim_customers c
LEFT JOIN fact_sales_transactions fs ON c.customer_id = fs.customer_id
WHERE fs.order_status NOT IN ('Returned', 'Cancelled')
GROUP BY c.acquisition_channel
ORDER BY lifetime_value DESC


-- (Payment Method Trends)
--Q20 Between Credit Card, Mobile Money, Bank Transfer — which of these payment methods are growing across our markets? (p1)
-- Is Mobile Money, which is critical across Africa, gaining enough adoption to warrant dedicated checkout optimization? (p2)


-- Query
SELECT 
	YEAR(fs.transaction_date) sale_year,
	fs.payment_method,
	COUNT(fs.transaction_id) transaction_count,
	ROUND(COUNT(fs.transaction_id) / SUM(COUNT(fs.transaction_id)) OVER(PARTITION BY YEAR(fs.transaction_date)) * 100,2) pct_share
FROM unilever_analytics.dim_countries co
LEFT JOIN unilever_analytics.dim_customers c ON c.country_id = co.country_id
LEFT JOIN fact_sales_transactions fs 
ON fs.customer_id = c.customer_id
WHERE fs.order_status NOT IN ('Returned', 'Cancelled')
AND fs.payment_method IS NOT NULL
GROUP BY sale_year, fs.payment_method
ORDER BY sale_year, transaction_count DESC


-- (Net Promoter Score by Segment)
--Q21 What is the NPS breakdown, Promoters, Passives, and Detractors across each of our product segments? Which segments are at risk of customer churn based on sentiment scores?


-- Query
SELECT 
	ds.segment_name,
	SUM(CASE WHEN fc.nps_score >= 9 THEN 1 ELSE 0 END) Promoters,
	SUM(CASE WHEN fc.nps_score BETWEEN 7 AND 8 THEN 1 ELSE 0 END) Passives,
	SUM(CASE WHEN fc.nps_score <= 6 THEN 1 ELSE 0 END) Detractors,
	COUNT(fc.review_id) Total_reviews,
	ROUND((SUM(CASE WHEN fc.nps_score >= 9 THEN 1 ELSE 0 END) - SUM(CASE WHEN fc.nps_score <= 6 THEN 1 ELSE 0 END)) / COUNT(fc.review_id) * 100, 1) Nps_score
FROM fact_customer_reviews fc
INNER JOIN dim_products dp ON fc.product_id = dp.product_id
INNER JOIN dim_brands db ON dp.brand_id = db.brand_id
INNER JOIN dim_categories dc ON db.category_id = dc.category_id
INNER JOIN dim_segments ds ON dc.segment_id = ds.segment_id
GROUP BY ds.segment_name
ORDER BY Nps_score DESC


-- (High-Value Lapsed Customers)
-- Q22 Which of our Platinum and Gold tier customers have not transacted in the last 6 months? What is the total revenue at risk if these lapsed customers churn permanently?


-- Query
SELECT 
	SUM(gross_revenue) Total_revenue
FROM (
SELECT 
	cu.customer_id,
	SUM(gross_revenue_usd) gross_revenue,
	MAX(fs.transaction_date) last_order_date
FROM unilever_analytics.dim_customers cu
JOIN unilever_analytics.fact_sales_transactions fs 
ON cu.customer_id = fs.customer_id
WHERE cu.loyalty_tier IN ('Platinum','Gold')
AND fs.order_status NOT IN ('Returned','Cancelled')
GROUP BY cu.customer_id
HAVING last_order_date < '2024-07-01'
)Lapsed_customers



